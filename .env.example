# ============================================================
# RHS.API – Environment Variables
# Copy this file to .env and fill in the real values.
# Do NOT commit .env to version control!
# ============================================================
# Uses .NET hierarchical config convention: Section__Key

# ----- Database -----
ConnectionStrings__DefaultConnection="Server=YOUR_DB_SERVER;Database=RHS_Database;User ID=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=true;Encrypt=False"

# ----- JWT -----
JwtSettings__SecretKey="YOUR_JWT_SECRET_KEY_MIN_32_CHARS"
JwtSettings__Issuer="RHS.API"
JwtSettings__Audience="RHS.Client"
JwtSettings__AccessTokenExpirationMinutes="60"
JwtSettings__RefreshTokenExpirationDays="7"

# ----- Google OAuth -----
GoogleAuth__ClientId="YOUR_GOOGLE_CLIENT_ID"
GoogleAuth__ClientSecret="YOUR_GOOGLE_CLIENT_SECRET"

# ----- OTP -----
OtpSettings__ExpirationMinutes="5"
OtpSettings__Length="6"

# ----- Email (SMTP) -----
EmailSettings__SmtpServer="smtp.gmail.com"
EmailSettings__SmtpPort="587"
EmailSettings__SenderEmail="your-email@example.com"
EmailSettings__SenderPassword="YOUR_EMAIL_APP_PASSWORD"
EmailSettings__SenderName="RHS Platform"

# ----- Cloudinary -----
Cloudinary__CloudName="YOUR_CLOUDINARY_CLOUD_NAME"
Cloudinary__ApiKey="YOUR_CLOUDINARY_API_KEY"
Cloudinary__ApiSecret="YOUR_CLOUDINARY_API_SECRET"

# ----- VnPay -----
VnPay__TmnCode="YOUR_VNP_TMNCODE"
VnPay__HashSecret="YOUR_VNP_HASH_SECRET"
VnPay__BaseUrl="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VnPay__ReturnUrl="https://localhost:7085/api/payment/payment-callback"
VnPay__Version="2.1.0"
VnPay__Command="pay"
VnPay__CurrCode="VND"
VnPay__Locale="vn"

# ----- FPT.AI -----
FptAi__ApiKey="YOUR_FPTAI_API_KEY"
FptAi__OcrEndpoint="https://api.fpt.ai/vision/idr/vnm"
FptAi__FaceMatchEndpoint="https://api.fpt.ai/dmp/checkface/v1"
FptAi__LivenessEndpoint="https://api.fpt.ai/dmp/liveness/v3"
FptAi__TimeoutSeconds="30"
FptAi__MaxFileSizeBytes="5242880"

# ----- Gemini AI -----
GeminiAi__ApiKey="YOUR_GEMINI_API_KEY"
GeminiAi__ModelName="gemini-2.5-flash"
GeminiAi__ApiUrl="https://generativelanguage.googleapis.com/v1beta"
GeminiAi__TimeoutSeconds="30"
